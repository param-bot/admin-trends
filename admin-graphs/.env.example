# Base URL of the analytics-service API — bare origin, no trailing slash and
# no /api suffix (the /api prefix is hardcoded in api.ts, since it's a
# service-wide convention, not a per-deployment one).
VITE_API_BASE_URL=http://localhost:3000

# Base URL of the admin API (game providers, etc.) — a separate service from
# the analytics-service above, hence its own axios instance (admin-client.ts).
VITE_ADMIN_API_BASE_URL=https://api.minibet.dev

# TEMPORARY hardcoded admin access token — until the admin panel redirects
# here with ?access_token=... instead. Get a real value from a teammate;
# never commit an actual token here, only in your local (gitignored) .env.
VITE_ADMIN_ACCESS_TOKEN=

# The real GET /api/player-trends/:accId is public — no auth header needed
# (confirmed with backend; ignore the x-token mention in the api reference doc).
#
# Force-mock switch for local dev without a reachable backend. Set to "false"
# to call the real endpoint for DEPOSIT/WITHDRAW (both live today). BET/WIN/GGR
# ignore this and always use mock data — the real backend 501s them (Phase 2).
# VITE_USE_MOCK_API=true
